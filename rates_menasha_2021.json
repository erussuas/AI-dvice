  "adjustmentClauses": {
    "PCAC": {
      "schedule": "PCAC",
      "description": "Power Cost Adjustment Clause — applies to all non-PCAC2 metered rates",
      "applicableTo": ["Rg-1","Rg-2","Gs-1","Gs-2","Cp-1","Cp-2","Cp-3","Ms-1","Ms-3"],
      "formula": "A = (C / S) - U",
      "variables": {
        "A": "Power cost adjustment rate ($/kWh), rounded to 4 decimal places",
        "C": "Non-PCAC2 cost of power purchased in the most recent month ($). Recorded in Acct 555 (Class A&B) or Acct 545 (Class C)",
        "S": "Total non-PCAC2 kWh sold in the most recent month",
        "U": "Base cost of power = $0.0727/kWh (constant until changed by PSCW)"
      },
      "baseCost_per_kWh": 0.0727,
      "roundingRule": "Nearest 1/100th of a cent",
      "notificationTrigger": "If monthly adjustment exceeds $0.0150/kWh more than 3 times in any 12-month rolling period, utility must notify PSCW"
    },
    "PCAC2": {
      "schedule": "PCAC2",
      "description": "Power Cost Adjustment Clause 2 — applies exclusively to Cp-4 tariff",
      "applicableTo": ["Cp-4"],
      "demandCostAdjustment": {
        "formula": "DCA = (WDC / RBD) - BDCF",
        "BDCF_by_month": {
          "July_August": 23.2413,
          "June_September": 19.4858,
          "all_other_months": 18.0153
        }
      },
      "energyCostAdjustment": {
        "formula": "ECA = (WEC / RE) - BECF",
        "BECF_per_kWh": 0.0328
      }
    }
  },

